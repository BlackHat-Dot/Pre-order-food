{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "cd order-delight-main && npm run build && cd .."
  },
  "deploy": {
    "startCommand": "bash start.sh",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5
  }
}