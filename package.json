{
  "name": "preorder-food-runtime",
  "private": true,
  "version": "1.0.0",
  "description": "Railway runtime for FastAPI + React/Vite application",
  "scripts": {
    "frontend": "cd order-delight-main && npm run dev -- --host 0.0.0.0 --port $PORT",
    "backend": "uvicorn app.main:app --host 0.0.0.0 --port 8000",
    "start": "concurrently \"npm run frontend\" \"npm run backend\"",
    "install:frontend": "cd order-delight-main && npm install",
    "install:root": "npm install",
    "postinstall": "npm run install:frontend"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "express": "^5.2.1",
    "http-proxy": "^1.18.1"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}