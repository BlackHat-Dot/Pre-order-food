# ===== REQUIRED =====
# Railway: Database add-on auto-sets DATABASE_URL (postgres:// is supported).
# After first deploy on Postgres, run: alembic upgrade head
# Local dev: Use PostgreSQL (set DATABASE_URL below)
# For Docker: postgresql://postgres:password@postgres:5432/preorder_db
# For local: postgresql://postgres:password@localhost:5432/preorder_db
DATABASE_URL=postgresql://postgres:password@localhost:5432/preorder_db

# OTP: memory (dev, lost on restart) | database (persisted in DB) | redis
OTP_STORAGE=database

# ===== APP CONFIG =====
ENV=local
APP_NAME=PreOrder Food API
API_PREFIX=/api/v1
LOG_LEVEL=INFO

# ===== SECURITY (CHANGE IN PRODUCTION) =====
JWT_SECRET_KEY=your-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ===== OPTIONAL ADMIN BOOTSTRAP =====
# Keep disabled by default in production. Enable only for first-time setup.
ENABLE_ADMIN_SEED=false
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PHONE=
DEFAULT_ADMIN_NAME=PreOrder Admin
DEFAULT_ADMIN_PASSWORD=

# ===== REDIS (Optional, for caching) =====
REDIS_URL=redis://localhost:6379/0

# ===== SENTRY (Optional, error tracking) =====
SENTRY_DSN=

# ===== AWS S3 (Optional, file uploads) =====
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_PUBLIC_BASE_URL=

# ===== TWILIO (Optional, SMS notifications) =====
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ===== MSG91 (Optional, phone verification) =====
MSG91_AUTH_KEY= 516068AcMCizCCa9Gf6a03447dP1

# ===== RAZORPAY (Optional, payments) =====
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
