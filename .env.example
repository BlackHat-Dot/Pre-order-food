# ===== REQUIRED =====
# Railway: Database add-on auto-sets DATABASE_URL
# Local dev: Use SQLite (set DATABASE_URL below)
DATABASE_URL=sqlite+aiosqlite:///./data/preorder.db

# ===== APP CONFIG =====
ENV=local
APP_NAME=PreOrder Food API
API_PREFIX=/api/v1
LOG_LEVEL=INFO

# ===== SECURITY (CHANGE IN PRODUCTION) =====
JWT_SECRET_KEY=your-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ===== REDIS (Optional, for caching) =====
REDIS_URL=redis://localhost:6379/0

# ===== SENTRY (Optional, error tracking) =====
SENTRY_DSN=

# ===== AWS S3 (Optional, file uploads) =====
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_PUBLIC_BASE_URL=

# ===== TWILIO (Optional, SMS notifications) =====
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ===== RAZORPAY (Optional, payments) =====
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
