ENV=local

# App
APP_NAME=PreOrder Food API
API_PREFIX=/api/v1
LOG_LEVEL=INFO

# Security
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=preorder
POSTGRES_USER=preorder
POSTGRES_PASSWORD=preorder
DATABASE_URL=sqlite+aiosqlite:///./data/preorder.db

# Redis
REDIS_URL=redis://redis:6379/0

# Sentry (optional)
SENTRY_DSN=

# AWS S3 (optional, enables real uploads)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_PUBLIC_BASE_URL=

# Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Razorpay (optional)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
